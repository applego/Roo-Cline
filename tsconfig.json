{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["es2020"],
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"strict": true,
		"outDir": "dist",
		"rootDir": "src",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"types": ["jest", "@jest/globals"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
