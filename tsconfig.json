{
	"compilerOptions": {
		"target": "ES2021",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"strict": true,
		"outDir": "out",
		"rootDir": "src",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"types": ["jest", "@jest/globals", "node", "mocha"],
		"jsx": "react-jsx"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
